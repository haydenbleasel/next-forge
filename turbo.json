{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "RESEND_TOKEN",
    "RESEND_FROM",
    "RESEND_AUDIENCE_ID",
    "BETTERSTACK_API_KEY",
    "BETTERSTACK_URL",
    "OPENAI_API_KEY",
    "STRIPE_SECRET_KEY",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "KNOCK_API_KEY",
    "KNOCK_SIGNING_KEY",
    "SEGMENT_WRITE_KEY"
  ]
}
